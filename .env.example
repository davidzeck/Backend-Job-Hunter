# Application
APP_NAME="Job Scout API"
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/jobscout

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth sessions (rotating refresh tokens — see docs/security.md)
# REFRESH_REUSE_GRACE_SECONDS=60
# SESSION_ABSOLUTE_MAX_DAYS=30
# PASSWORD_RESET_EXPIRE_MINUTES=60
# EMAIL_VERIFICATION_EXPIRE_HOURS=24
# Base URL used in password-reset / verification email links
FRONTEND_BASE_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Google Gemini AI (ATS analysis + CV tailoring)
# Get your key at https://aistudio.google.com/apikey
# REQUIRED in production/staging — optional in development (AI features disabled without it)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# S3 / MinIO Object Storage
# Leave S3_ENDPOINT_URL empty for real AWS S3; set to http://localhost:9000 for local MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=jobscout-cvs
S3_AWS_ACCESS_KEY_ID=minioadmin
S3_AWS_SECRET_ACCESS_KEY=minioadmin

# SMTP (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@jobscout.co.ke

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# Scraping
SCRAPE_TIMEOUT_SECONDS=30
SCRAPE_MAX_RETRIES=3
